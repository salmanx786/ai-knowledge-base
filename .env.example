DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/ai_knowledge_base

JWT_SECRET=replace_with_a_long_random_secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# Local filesystem root for uploaded documents (created on first upload).
UPLOAD_DIR=uploads

# Google Gemini (RAG chat). GEMINI_API_KEY is optional at startup: the app boots
# without it, but calling POST /api/v1/chat without it returns a server error.
GEMINI_API_KEY=replace_with_your_gemini_api_key
GEMINI_MODEL=gemini-2.5-flash